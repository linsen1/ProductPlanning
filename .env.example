# ── AI 策划智能体环境变量配置 ──────────────────────────────────────────────────
# 复制本文件为 .env，填写实际值后启动

# LLM 后端选择：qwen（推荐）或 openai
LLM_BACKEND=qwen

# 通义千问（DashScope）配置 —— LLM_BACKEND=qwen 时必填
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen3-235b-a22b
EMBEDDING_MODEL=text-embedding-v4

# OpenAI 配置 —— LLM_BACKEND=openai 时必填
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o

# 博查搜索配置（竞品分析用，未配置 BOCHA_API_KEY 则跳过联网竞品搜索）
BOCHA_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
BOCHA_SEARCH_COUNT=10          # 每次搜索返回结果数（博查上限50）
BOCHA_FRESHNESS=noLimit        # oneDay/oneWeek/oneMonth/oneYear/noLimit
BOCHA_USE_AISEARCH=1           # 1=竞品分析走AI搜索(更深,稍慢稍贵)；0=只用普通web搜索
# BOCHA_API_URL=https://api.bochaai.com/v1/web-search
# BOCHA_AISEARCH_URL=https://api.bochaai.com/v1/ai-search

# 知识库配置（一般不需要修改）
KB_DIR=./data          # 存放 .md 案例文件的目录
VECTOR_DB_DIR=./chroma_db   # 向量数据库存储目录
TOP_K=3                # 每次检索返回的案例片段数量
